#!/bin/bash
# Supervisor - Automatically spawn and clean up worker sessions based on beads ready queue.
#
# Usage: ./bot-templates/Supervisor <backend> <workdir> [interval=<seconds>]
#
# Logic (polled every INTERVAL seconds):
#   1. Read unassigned open beads from agent/beads/ready.
#   2. For each ready bead:
#        a. Map its capability_level label to a model tier (low→haiku, high→opus, *→sonnet).
#        b. Look for a stopped session whose assigned bead is now closed AND whose model tier
#           matches.  If found, restart it and reassign (bot reuse per bd-frk.3 findings).
#           Restart replays the original backend command — model cannot change on restart,
#           so reuse is only valid when the tier matches.
#        c. Otherwise spawn a new worker: echo "new <backend> <workdir> model=<tier>" | 9p write agent/ctl.
#        d. Write a minimal context prompt to the session.
#        e. Claim the bead with the session ID as assignee.
#   3. Scan all sessions:
#        - If a session is stopped or exited AND its assigned bead (if any) is closed, kill it.
#
# Model tier mapping (claude/kiro backends):
#   capability:low      → haiku
#   capability:standard → sonnet   (default when no label)
#   capability:high     → opus
#
# Ollama backend: low→smallest model, standard→mid, high→largest.
# Supervisor does not enumerate ollama models; pass explicit model names via capability labels
# or customise cap_to_model() below for your rig.
#
# Refs: bd-frk.7 (capability labels), bd-frk.10 (model tiers), bd-frk.3 (restart findings).

set -euo pipefail

if [ $# -lt 2 ]; then
    echo "Usage: $0 <backend> <workdir> [interval=<seconds>]" >&2
    exit 1
fi

BACKEND="$1"
WORKDIR="$2"
INTERVAL=5

# Parse optional keyword arguments (interval=N)
for arg in "${@:3}"; do
    case "$arg" in
        interval=*) INTERVAL="${arg#interval=}" ;;
        *) echo "Unknown argument: $arg" >&2; exit 1 ;;
    esac
done

AGENT_MOUNT="agent"

# Verify anvillm namespace is reachable.
NAMESPACE=$(namespace 2>/dev/null) || true
if [ -z "$NAMESPACE" ]; then
    echo "Error: No namespace found. Is anvillm running?" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# cap_to_model <level>
#   Maps a portable capability level string to a backend model name.
#   Extend this function for ollama or custom backends.
# ---------------------------------------------------------------------------
cap_to_model() {
    local level="$1"
    case "$BACKEND" in
        claude|kiro-cli)
            case "$level" in
                low)  echo "haiku" ;;
                high) echo "opus"  ;;
                *)    echo "sonnet" ;;  # standard or empty
            esac
            ;;
        ollama)
            # Ollama: caller should set explicit capability labels with model names,
            # or customise these defaults for their rig.
            case "$level" in
                low)  echo "qwen2.5:3b"  ;;
                high) echo "qwen2.5:32b" ;;
                *)    echo "qwen2.5:14b" ;;
            esac
            ;;
        *)
            # Unknown backend: return empty (use backend default)
            echo ""
            ;;
    esac
}

# ---------------------------------------------------------------------------
# bead_assignee <bead-id>
#   Returns the current assignee of a bead (empty string if none/null).
# ---------------------------------------------------------------------------
bead_assignee() {
    9p read "${AGENT_MOUNT}/beads/$1/json" 2>/dev/null \
        | jq -r '.assignee // empty' 2>/dev/null || echo ""
}

# ---------------------------------------------------------------------------
# bead_status <bead-id>
#   Returns the status of a bead (open/in_progress/closed).
# ---------------------------------------------------------------------------
bead_status() {
    9p read "${AGENT_MOUNT}/beads/$1/json" 2>/dev/null \
        | jq -r '.status // empty' 2>/dev/null || echo ""
}

# ---------------------------------------------------------------------------
# session_model <session-id>
#   Returns the model the session was started with (empty = backend default).
# ---------------------------------------------------------------------------
session_model() {
    9p read "${AGENT_MOUNT}/$1/model" 2>/dev/null || echo ""
}

# ---------------------------------------------------------------------------
# session_state <session-id>
#   Returns the state string for a session.
# ---------------------------------------------------------------------------
session_state() {
    9p read "${AGENT_MOUNT}/$1/state" 2>/dev/null || echo "unknown"
}

# ---------------------------------------------------------------------------
# spawn_worker <bead-id> <model-tier>
#   Starts a new worker session at the given model tier and returns its ID.
# ---------------------------------------------------------------------------
spawn_worker() {
    local bead_id="$1"
    local model_tier="$2"

    if [ -n "$model_tier" ]; then
        echo "new ${BACKEND} ${WORKDIR} model=${model_tier}" \
            | 9p write "${AGENT_MOUNT}/ctl"
    else
        echo "new ${BACKEND} ${WORKDIR}" \
            | 9p write "${AGENT_MOUNT}/ctl"
    fi

    # The most recently added session appears first in the list.
    9p read "${AGENT_MOUNT}/list" | awk 'NR==1{print $1}'
}

# ---------------------------------------------------------------------------
# write_worker_context <session-id> <bead-id> <supervisor-hint>
#   Writes a minimal context prompt to a worker session.
# ---------------------------------------------------------------------------
write_worker_context() {
    local sess_id="$1"
    local bead_id="$2"

    cat <<EOF | 9p write "${AGENT_MOUNT}/${sess_id}/context"
## Role

You are a worker bot.  Your sole task is to complete bead ${bead_id}.

Workflow:
1. Load the beads skill.
2. Claim and work on bead ${bead_id} (it is already assigned to you).
3. When the bead is complete, send a PROMPT_RESPONSE to the user with:
     Status: completed
     Beads: ${bead_id}
     Errors: none  (or list errors)
4. If you cannot complete the bead, fail it: echo "fail ${bead_id} '<reason>'" | 9p write agent/beads/ctl

Do not work on any other bead.

## Information Requests

If you need information about the codebase, architecture, or external libraries:
1. Send a QUERY_REQUEST to the user with:
     Query: <specific question>
     Context: <optional hints>
2. Go idle and wait for QUERY_RESPONSE
3. Resume work when the response arrives

Do not explore the codebase yourself. Do not use code exploration tools. Do not use web search.
EOF
}

# ---------------------------------------------------------------------------
# find_reusable_session <model-tier>
#   Scans stopped sessions for one whose assigned bead is closed and whose
#   model matches model-tier.  Prints the session ID or nothing.
# ---------------------------------------------------------------------------
find_reusable_session() {
    local want_model="$1"

    while IFS=$'\t' read -r sess_id _backend state _alias _cwd; do
        [ "$state" = "stopped" ] || continue

        local sess_model
        sess_model=$(session_model "$sess_id")

        # Model must match (both empty counts as a match for default-tier).
        [ "$sess_model" = "$want_model" ] || continue

        # The session's assignee bead must be closed (or no bead → session idle).
        local assignee_bead=""
        # We stored the bead ID by claiming it with the session ID as assignee.
        # Reverse-look up: find a bead whose assignee == sess_id.
        assignee_bead=$(9p read "${AGENT_MOUNT}/beads/list" 2>/dev/null \
            | jq -r --arg sid "$sess_id" \
                '.[] | select(.assignee == $sid) | .id' \
            | head -1 || echo "")

        if [ -z "$assignee_bead" ]; then
            # No assigned bead — session is free.
            echo "$sess_id"
            return
        fi

        local bstatus
        bstatus=$(bead_status "$assignee_bead")
        if [ "$bstatus" = "closed" ]; then
            echo "$sess_id"
            return
        fi
    done < <(9p read "${AGENT_MOUNT}/list" 2>/dev/null || true)
}

# ---------------------------------------------------------------------------
# cleanup_finished_sessions
#   Kills stopped/exited sessions whose assigned bead (if any) is closed.
# ---------------------------------------------------------------------------
cleanup_finished_sessions() {
    while IFS=$'\t' read -r sess_id _backend state _alias _cwd; do
        case "$state" in
            stopped|exited) ;;
            *) continue ;;
        esac

        # Find bead assigned to this session.
        local assigned_bead=""
        assigned_bead=$(9p read "${AGENT_MOUNT}/beads/list" 2>/dev/null \
            | jq -r --arg sid "$sess_id" \
                '.[] | select(.assignee == $sid) | .id' \
            | head -1 || echo "")

        [ -n "$assigned_bead" ] || continue

        local bstatus
        bstatus=$(bead_status "$assigned_bead")
        if [ "$bstatus" = "closed" ]; then
            echo "[supervisor] killing finished session ${sess_id} (bead ${assigned_bead} closed)"
            echo "kill" | 9p write "${AGENT_MOUNT}/${sess_id}/ctl" 2>/dev/null || true
        fi
    done < <(9p read "${AGENT_MOUNT}/list" 2>/dev/null || true)
}

# ---------------------------------------------------------------------------
# dispatch_ready_beads
#   For each ready unassigned bead, spawn or reuse a worker and claim it.
# ---------------------------------------------------------------------------
dispatch_ready_beads() {
    local ready_json
    ready_json=$(9p read "${AGENT_MOUNT}/beads/ready" 2>/dev/null || echo "[]")

    echo "$ready_json" \
        | jq -r '.[] | select((.assignee == null) or (.assignee == "")) | [.id, (.capability_level // "")] | @tsv' \
    | while IFS=$'\t' read -r bead_id cap_level; do
        local model_tier
        model_tier=$(cap_to_model "$cap_level")

        # Look for a stopped session with the same model to reuse.
        local reuse_id=""
        reuse_id=$(find_reusable_session "$model_tier")

        local sess_id
        if [ -n "$reuse_id" ]; then
            echo "[supervisor] reusing session ${reuse_id} (model=${model_tier}) for bead ${bead_id}"
            echo "restart" | 9p write "${AGENT_MOUNT}/${reuse_id}/ctl" 2>/dev/null || {
                echo "[supervisor] restart failed for ${reuse_id}, spawning fresh"
                reuse_id=""
            }
            sess_id="$reuse_id"
        fi

        if [ -z "$sess_id" ]; then
            echo "[supervisor] spawning ${BACKEND} model=${model_tier:-default} for bead ${bead_id}"
            sess_id=$(spawn_worker "$bead_id" "$model_tier")
            if [ -z "$sess_id" ]; then
                echo "[supervisor] ERROR: failed to get session ID for bead ${bead_id}" >&2
                continue
            fi
        fi

        # Write context and claim the bead.
        write_worker_context "$sess_id" "$bead_id"
        echo "claim ${bead_id} ${sess_id}" | 9p write "${AGENT_MOUNT}/beads/ctl" || {
            echo "[supervisor] WARNING: failed to claim ${bead_id} for session ${sess_id}" >&2
        }
        echo "[supervisor] bead ${bead_id} → session ${sess_id} (model=${model_tier:-default})"
    done
}

# ---------------------------------------------------------------------------
# Main loop
# ---------------------------------------------------------------------------
echo "[supervisor] starting — backend=${BACKEND} workdir=${WORKDIR} interval=${INTERVAL}s"

while true; do
    dispatch_ready_beads
    cleanup_finished_sessions
    sleep "$INTERVAL"
done
