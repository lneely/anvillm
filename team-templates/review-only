#!/bin/bash
# review-only - Spawn a team for the review-only workflow
# Roles: conductor, reviewer, tester
# Usage: review-only [backend] [workdir]

set -e

BACKEND="${1:-claude}"
WORKDIR="${2:-$(pwd)}"

anvilspawn "$BACKEND" conductor "$WORKDIR"
anvilspawn "$BACKEND" reviewer  "$WORKDIR"
anvilspawn "$BACKEND" tester    "$WORKDIR"
