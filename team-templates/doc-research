#!/bin/bash
# doc-research - Spawn a team for the doc-research workflow
# Roles: conductor, researcher, author, technical-editor
# Usage: doc-research [backend] [workdir]

set -e

BACKEND="${1:-claude}"
WORKDIR="${2:-$(pwd)}"

anvilspawn "$BACKEND" conductor        "$WORKDIR"
anvilspawn "$BACKEND" researcher       "$WORKDIR"
anvilspawn "$BACKEND" author           "$WORKDIR"
anvilspawn "$BACKEND" technical-editor "$WORKDIR"
