#!/bin/bash
# doc - Spawn a team for the doc workflow
# Roles: conductor, author, technical-editor
# Usage: doc [backend] [workdir]

set -e

BACKEND="${1:-claude}"
WORKDIR="${2:-$(pwd)}"

anvilspawn "$BACKEND" conductor        "$WORKDIR"
anvilspawn "$BACKEND" author           "$WORKDIR"
anvilspawn "$BACKEND" technical-editor "$WORKDIR"
