#!/bin/bash
# bugfix - Spawn a team for the bugfix workflow
# Roles: conductor, developer, reviewer, tester
# Usage: bugfix [backend] [workdir]

set -e

BACKEND="${1:-claude}"
WORKDIR="${2:-$(pwd)}"

anvilspawn "$BACKEND" conductor "$WORKDIR"
anvilspawn "$BACKEND" developer "$WORKDIR"
anvilspawn "$BACKEND" reviewer  "$WORKDIR"
anvilspawn "$BACKEND" tester    "$WORKDIR"
