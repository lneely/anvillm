{
  "name": "anvillm-agent",
  "description": "Agent for AnviLLM multi-agent workflows with mailbox communication",
  "prompt": "",
  "tools": [
    "code",
    "read",
    "write",
    "glob",
    "grep",
    "introspect",
    "report",
    "thinking",
    "todo",
    "aws",
    "subagent",
    "web_fetch",
    "@anvilmcp/execute_code",
    "@superpowers-mcp-server/execute_elevated_bash",
    "@superpowers-mcp-server/request_file"
  ],
  "allowedTools": [
    "code",
    "read",
    "write",
    "glob",
    "grep",
    "introspect",
    "report",
    "thinking",
    "todo",
    "aws",
    "subagent",
    "web_fetch",
    "@anvilmcp/execute_code",
    "@superpowers-mcp-server/execute_elevated_bash",
    "@superpowers-mcp-server/request_file"
   ],
  "toolsSettings": {
    "shell": {
      "autoAllowReadonly": true
    }
  },
  "includeMcpJson": true,
  "hooks": {
    "agentSpawn": [
      {
        "command": "anvillm-hook agentSpawn"
      }
    ],
    "userPromptSubmit": [
      {
        "command": "anvillm-hook userPromptSubmit"
      }
    ],
    "stop": [
      {
        "command": "anvillm-hook stop"
      }
    ]
  }
}
