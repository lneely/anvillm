#!/bin/bash
# Orphan bead recovery: find in_progress beads whose assignee session has died
# and spawn a replacement agent with bootstrap context.
# Intended to run from cron every 5 minutes.
set -euo pipefail

MCPTOOLS="$HOME/.config/anvillm/mcptools"
LOG_PREFIX="[orphan-check $(date '+%Y-%m-%d %H:%M:%S')]"

# Default backend for replacement agents (override via ANVILLM_DEFAULT_BACKEND)
DEFAULT_BACKEND="${ANVILLM_DEFAULT_BACKEND:-claude}"

log() { echo "$LOG_PREFIX $*"; }
warn() { echo "$LOG_PREFIX WARNING: $*" >&2; }

# Get live session IDs
LIVE_SESSIONS=$(9p read anvillm/list 2>/dev/null | awk -F'\t' '{print $1}' || true)

# Get all mounts
MTAB=$(9p read anvillm/beads/mtab 2>/dev/null || true)
if [ -z "$MTAB" ]; then
    log "no mounts, nothing to do"
    exit 0
fi

while IFS=$'\t' read -r MOUNT CWD; do
    [ -z "$MOUNT" ] && continue

    # Find in_progress beads with their assignees
    IN_PROGRESS=$(9p read "anvillm/beads/$MOUNT/list" 2>/dev/null \
        | jq -r '.[] | select(.status == "in_progress") | [.id, (.assignee // "")] | @tsv' \
        2>/dev/null || true)

    [ -z "$IN_PROGRESS" ] && continue

    while IFS=$'\t' read -r BEAD_ID ASSIGNEE; do
        [ -z "$BEAD_ID" ] && continue

        # Skip if assignee is still alive
        if [ -n "$ASSIGNEE" ] && echo "$LIVE_SESSIONS" | grep -qx "$ASSIGNEE"; then
            continue
        fi

        log "orphan: $BEAD_ID (was: ${ASSIGNEE:-unassigned}) mount=$MOUNT cwd=$CWD"

        # Build bootstrap prompt
        BOOTSTRAP=$(bash "$MCPTOOLS/bootstrap_session.sh" \
            --mount "$MOUNT" --id "$BEAD_ID" 2>/dev/null) || {
            warn "bootstrap failed for $BEAD_ID, skipping"
            continue
        }

        # Spawn replacement agent
        echo "new $DEFAULT_BACKEND $CWD" | 9p write anvillm/ctl 2>/dev/null || {
            warn "failed to spawn agent for $BEAD_ID"
            continue
        }

        # Wait for new session to appear (up to 10s), then inject bootstrap
        NEW_SESSION=""
        for _ in $(seq 1 10); do
            NEW_SESSION=$(9p read anvillm/list 2>/dev/null \
                | awk -F'\t' -v cwd="$CWD" '$5 == cwd {print $1; exit}' || true)
            # Exclude the dead assignee
            [ "$NEW_SESSION" = "$ASSIGNEE" ] && NEW_SESSION=""
            [ -n "$NEW_SESSION" ] && break
            sleep 1
        done

        if [ -n "$NEW_SESSION" ]; then
            echo "$BOOTSTRAP" | 9p write "anvillm/$NEW_SESSION/context" 2>/dev/null || true
            log "spawned $NEW_SESSION for $BEAD_ID"
        else
            warn "timed out waiting for new session for $BEAD_ID in $CWD"
        fi

    done <<< "$IN_PROGRESS"
done <<< "$MTAB"
